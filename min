<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>👑 ADMIN SPACEMAN</title>
    <style>
        body { font-family: 'Press Start 2P', sans-serif; background: #0a0a1f; color: white; text-align:center; margin:0; padding:20px; }
        .container { max-width: 650px; margin:auto; background:#1a1a2e; padding:20px; border:4px solid #ef4444; border-radius:15px; }
        button { width:100%; padding:15px; margin:10px 0; font-size:18px; border:none; border-radius:50px; cursor:pointer; }
        .btn-green { background:#22c55e; color:black; }
        .btn-red { background:#ef4444; color:white; }
        input { width:90%; padding:12px; margin:8px 0; background:#334155; color:white; border:none; border-radius:8px; }
    </style>
</head>
<body>
<div class="container">
    <h1>👑 ADMIN CONTROL</h1>
    
    <h3>Tambah Saldo User</h3>
    <input type="text" id="target" placeholder="Username">
    <input type="number" id="amount" placeholder="Jumlah Saldo">
    <button onclick="addSaldo()" class="btn-green">💰 TAMBAH SALDO</button>

    <h3>Force Crash</h3>
    <input type="text" id="fuser" placeholder="Username">
    <input type="number" id="fmult" value="3.5" step="0.1">
    <button onclick="setForce()" class="btn-red">💥 SET FORCE CRASH</button>
</div>

<script>
    function addSaldo() {
        let user = document.getElementById('target').value.trim();
        let amt = document.getElementById('amount').value;
        if (user && amt) alert(`✅ Saldo ${user} ditambah Rp ${amt}`);
        else alert("Isi username dan jumlah!");
    }
    function setForce() {
        let user = document.getElementById('fuser').value.trim();
        let mult = document.getElementById('fmult').value;
        if (user) alert(`💥 Force crash ${user} diatur ke ${mult}x`);
    }
</script>
</body>
</html>
